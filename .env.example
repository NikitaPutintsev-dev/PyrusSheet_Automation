# Pyrus bot credentials (see https://pyrus.com/en/help/api/authorization)
PYRUS_LOGIN=bot@example.com
PYRUS_SECURITY_KEY=

# Optional: override API base after auth (usually returned by /auth)
# PYRUS_API_URL=https://api.pyrus.com/v4/

PYRUS_FORM_ID=12345

# Google Sheet
SPREADSHEET_ID=

# Path to service account JSON file OR paste JSON into GOOGLE_SERVICE_ACCOUNT_JSON
GOOGLE_APPLICATION_CREDENTIALS=
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Mapping file (YAML)
MAPPING_CONFIG_PATH=config/mapping.yaml

# Optional: log file in addition to stdout
# LOG_FILE_PATH=sync.log
